# Supabase — copie este arquivo para .env e preencha com os dados do seu projeto.
# Painel do Supabase > Project Settings > API
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua-chave-anon-publica

# --- Stripe (somente nas Edge Functions; NÃO usar no cliente) ---
# Defina via: supabase secrets set NOME=valor
# STRIPE_SECRET_KEY=sk_live_ou_test
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_MONTHLY=price_...
# STRIPE_PRICE_ANNUAL=price_...
# SITE_URL=https://seu-site.com
# (SUPABASE_URL e SUPABASE_SERVICE_ROLE_KEY já existem no ambiente das functions)
